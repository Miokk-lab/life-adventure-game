# Google AI
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# DeepSeek (primary text generation)
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Agnes AI (fallback for text + image + video)
AGNES_API_KEY=your-agnes-api-key-here
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
AGNES_TEXT_MODEL=agnes-2.0-flash
AGNES_IMAGE_MODEL=agnes-image-2.1-flash
AGNES_VIDEO_MODEL=agnes-video-v2.0

# Optional: legacy video API
VIDEO_API_ENDPOINT=
VIDEO_API_KEY=

# Server URL (for generated image URLs in Cloud Run, set to your Cloud Run URL)
SERVER_URL=http://localhost:3001

# ADK deployment target
DEPLOYMENT_TARGET=agent_engine
